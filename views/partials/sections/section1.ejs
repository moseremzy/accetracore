<div class="top-stats">
  <div class="stat-card blue">
    <div class="stat-content">
      <div class="text">
        <p class="label">Current Balance</p>
        <h2><%
          const formattedBalance = new Intl.NumberFormat("en", {
           style: "currency",
           currency: user.currencyCode
         }).format(user.balance);
       %>

       <%= formattedBalance %>
      </h2>
      </div>
      <i class="fas fa-wallet section1-icon"></i>
    </div>
  </div>

  <div class="stat-card green">
    <div class="stat-content">
      <div class="text">
        <p class="label">Monthly Income</p>
        <h2>
        <%
          const formatted_monthly_income = new Intl.NumberFormat("en", {
            style: "currency",
            currency: user.currencyCode
          }).format(user.monthly_income);
        %>

        <%= formatted_monthly_income %>
        </h2>
      </div>
      <i class="fas fa-arrow-down section1-icon"></i>
    </div>
  </div>

  <div class="stat-card red">
    <div class="stat-content">
      <div class="text">
        <p class="label">Monthly Outgoing</p>
        <h2>
          <%
          const formatted_monthly_outgoing = new Intl.NumberFormat("en", {
            style: "currency",
            currency: user.currencyCode
          }).format(user.monthly_outgoing);
         %>

        <%= formatted_monthly_outgoing %>
        </h2>
      </div>
      <i class="fas fa-arrow-up section1-icon"></i>
    </div>
  </div>

  <div class="stat-card purple">
    <div class="stat-content">
      <div class="text">
        <p class="label">Transaction Limit</p>
        <h2>
        <%
          const formatted_transaction_limit = new Intl.NumberFormat("en", {
            style: "currency",
            currency: user.currencyCode
          }).format(user.transaction_limit);
        %>

        <%= formatted_transaction_limit %>
        </h2>
      </div>
      <i class="fas fa-chart-line section1-icon"></i>
    </div>
  </div>
</div>

<style>
.top-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 20px;
  margin: 20px 0 0 0;
}

.stat-card {
  border-left: 6px solid;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 6px 12px rgba(0,0,0,0.06);
  transition: transform 0.2s ease;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.stat-card:hover {
  transform: translateY(-3px);
}

.stat-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.text {
  flex: 1 1 auto;
  min-width: 0;
}

.stat-card .label {
  font-size: 12px;
  margin: 0 0 5px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  word-break: break-word;
}

.stat-card h2 {
  font-size: 18px;
  margin: 0;
  word-break: break-word;
}

.section1-icon {
  font-size: 16px;
  padding: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* Blue Card */
.stat-card.blue {
  border-color: #007BFF;
  background: linear-gradient(to right, #007BFF 0%, #c3d1e4 100%);
  color: white;
}

.stat-card.blue i {
  background-color: #007BFF;
  color: #ffffff;
}

/* Green Card */
.stat-card.green {
  border-color: #28a745;
  background: linear-gradient(to right, #28a745 0%, #c3e4ca 100%);
  color: #ffffff;
}

.stat-card.green h2,
.stat-card.green .label {
  color: #ffffff;
}

.stat-card.green i {
  background-color: #28a745;
  color: #ffffff;
}

/* Red Card */
.stat-card.red {
  border-color: #dc3545;
  background: linear-gradient(to right, #dc3545 0%, #ddb5b5 100%);
  color: #ffffff;
}

.stat-card.red h2,
.stat-card.red .label {
  color: #ffffff;
}

.stat-card.red i {
  background-color: #dc3545;
  color: #ffffff;
}

/* Purple Card */
.stat-card.purple {
  border-color: #6f42c1;
  background: linear-gradient(to right, #6f42c1 0%, #daa9df 100%);
  color: #ffffff;
}

.stat-card.purple h2,
.stat-card.purple .label {
  color: #ffffff;
}

.stat-card.purple i {
  background-color: #6f42c1;
  color: #ffffff;
}

/* Extra mobile-friendly layout for small devices */
@media (max-width: 400px) {
  .top-stats {
    grid-template-columns: 1fr;
  }

  .section1-icon {
    font-size: 14px;
    padding: 8px;
  }

  .stat-card h2 {
    font-size: 16px;
  }
}
</style>
