<div class="main-content">
      <div class="balance-card">
        <div class="balance-header">
          <div class="greeting-box">
            <img src="/<%= user.profile_photo %>" alt="User Photo" class="user-pic">
            <div>
              <p class="greeting">Welcome Back<br><strong><%= user.firstname %></strong></p>
            </div>
          </div>
          <div class="date-time">
            <p id="live_time">06:35:09</p>
            <span id="section2_date" class="notranslate"></span>
          </div>
        </div>
        
        <p class="available">Available Balance</p>
        <h2 id = "available-balance">
          <%
          const formatted_balance = new Intl.NumberFormat("en", {
            style: "currency",
            currency: user.currencyCode
          }).format(user.balance);
         %>

        <%= formatted_balance %>
        <%= user.currencyCode %>
        </h2>
        
        <div class="balance-footer">
          <div class="account-info">
            <p>Your Account Number</p>
            <strong><%= user.account_number %></strong>
            <% if (user.account_status === 'Active') { %>
              <span class="status">🟢 <%= user.account_status %></span>
            <% } else { %>
              <span class="status">🔴 <%= user.account_status %></span>
            <% } %>            
          </div>
          
          <div class="buttons">
            <a href="/account/transactions" class="btn btn-outline" style="text-decoration: none;">
              <i class="fas fa-receipt"></i> Transactions
            </a>            
            <button class="btn btn-primary">
              <i class="fas fa-arrow-up-right-dots"></i> Top up
            </button>
          </div>
        </div>
      </div>
    </div>

  
