<div class="modal" style="display: none;" id="networkModal">
    <div class="modal-content">
        <div class="modal-header">Network Error</div>
        <div class="modal-body">We are unable to process your request right now due to a network issue. Please try again.</div>
        <div class="modal-footer">
            <button class="btn" onclick="closeModal()">Okay</button>
        </div>
    </div>
</div>


<style>
    .modal {
        display: flex;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        justify-content: center;
        align-items: center;
    }
    .modal-content {
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        text-align: center;
        width: 350px;
    }
    .modal-header {
        font-size: 18px;
        font-weight: bold;
        color: #d9534f;
        margin-bottom: 10px;
    }
    .modal-body {
        font-size: 14px;
        color: #333;
        margin-bottom: 20px;
    }
    .modal-footer {
        text-align: center;
    }
    .modal-footer .btn {
        background: #d9534f;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 6px;
        font-size: 14px;
        cursor: pointer;
        transition: background 0.3s;
    }
    .modal-footer .btn:hover {
        background: #c9302c;
    }
</style>

<script>
    function closeModal() {

        document.getElementById('networkModal').style.display = 'none';

    }
</script>