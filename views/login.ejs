<body>

    <div class="main">
        <div id="google_translate_element" style="display: block; width: 10%; margin: 0px auto 10px auto;"></div>
        <section class="signup">
            <!-- <img src="images/signup-bg.jpg" alt=""> -->
            <div class="container">
                <div class="signup-content">
                    <form id="signup-form" class="signup-form" action="/login" method="post">
                        <h2 class="form-title">Login Account</h2>
                            
                        <% if (typeof message != 'undefined') { %>
                            <p id="err" style="color:red; font-weight: bold; text-align: center; margin: 0px 0px 20px 0px;"><%= message %></p>
                            <% } %>

