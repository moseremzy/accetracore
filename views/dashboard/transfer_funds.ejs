<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bank Transfer</title>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js"></script>
    <script src="/js/interactive.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/css/transfer.css">
    <meta name="google" content="notranslate">
    <link rel="icon" href="/assets/img/favicon.png" type="image/x-icon" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Lora:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://kit.fontawesome.com/0855e51304.js" crossorigin="anonymous"></script>
    <%- settings.LIVECHAT %>
</head>
<body>

    
  <!--overlay--> <%- include('../partials/overlay') %>

  <!--overlay--> <%- include('../partials/error_modal') %>
 
   <div class="container">

    <!--side bar--> <%- include('../partials/sidebar') %>
    
    <div class="sub_container">
    
    <!--header--> <%- include('../partials/header') %>
    
    <div class = "overall_grid">
    
    <h1>
        <%= (transfer_type === 'Local Transfer' || transfer_type === 'International Wire') 
            ? transfer_type 
            : 'Transfer Funds' %>
    </h1>          

    <div class="transfer-container">

        <div class="account-balance">
          <p>Available Balance: 
            <span id="balance">
            <%
              const formatted_balance = new Intl.NumberFormat("en", {
                style: "currency",
                currency: user.currencyCode
              }).format(user.balance);
            %>

           <%= formatted_balance %>
            </span>
          </p>
        </div>

        <form id="transfer_funds_form">
            <div class="form-group">
              <label for="account-number">Recipient Account Number</label>
              <input type="text" id="account-number" name="recipient_account_number" placeholder="Enter account number" required>
              <i class="fas fa-hashtag"></i> <!-- Account number icon -->
            </div>
          
            <div class="form-group">
              <label for="account-name">Recipient Name</label>
              <input type="text" id="account-name" name="recipient_name" placeholder="Full Name" required>
              <i class="fas fa-user"></i> <!-- User icon -->
            </div>
          
            <div class="form-group">
              <label for="bank-name">Bank Name</label>
              <input type="text" id="bank-name" name="bank_name" placeholder="Enter bank name" required>
              <i class="fas fa-university"></i> <!-- Bank icon -->
            </div>
          
            <div class="form-group">
              <label for="amount">Amount (<%= user.currencyCode %>)</label>
              <input type="number" id="amount" name="amount" placeholder="Enter amount" required>
              <i class="fas fa-dollar-sign"></i> <!-- Dollar icon -->
            </div>
          
            <% if (transfer_type === 'International Wire') { %> <!-- DISPLAY SWIFT CODE ONLY IF NA INTERNATIONAL TRANSFER -->
                <div class="form-group">
                  <label for="swift">Swift Code (Optional)</label>
                  <input type="text" id="swift" placeholder="Enter Swift Code">
                  <i class="fas fa-random"></i> <!-- Random/swap icon for Swift -->
                </div>
            <% } %>
          
            <div class="form-group">
              <label for="narration">Narration (Optional)</label>
              <input type="text" id="narration" placeholder="Payment for...">
              <i class="fas fa-pen"></i> <!-- Pen icon for narration -->
            </div>
          
            <button type="submit" class="btn">Transfer</button>
          </form>
          
        <p class="small-text">Ensure all details are correct before proceeding.</p>
    </div>
    
</div>  
             
</div>

<!-- footer <%- include('../partials/footer') %> -->

</div>
    
<div id="google_translate_element" style="display:none"></div>
    <!-- define function BEFORE loading Google Translate -->
<script type="text/javascript">
  function googleTranslateElementInit() {
    new google.translate.TranslateElement({pageLanguage: "en"}, 'google_translate_element');
  }

  function changeLanguageByButtonClick() {
    var language = document.getElementById("language").value;
    var selectField = document.querySelector("#google_translate_element select");
    for (var i = 0; i < selectField.children.length; i++) {
      var option = selectField.children[i];
      if (option.value === language) {
        selectField.selectedIndex = i;
        selectField.dispatchEvent(new Event('change'));
        break;
      }
    }
  }
</script>

<!-- Now load the script -->
<script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

<script src="/js/helper.js"></script>
</body>
</html>
