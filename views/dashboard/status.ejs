<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Transfer Submitted</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      font-family: 'Inter', sans-serif;
      background-color: #f5f7fa;
      color: #1a1a1a;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .card {
      background: #ffffff;
      padding: 50px 40px;
      border-radius: 12px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
      text-align: center;
      width: 90%;
      max-width: 400px;
    }

    .checkmark {
      width: 70px;
      height: 70px;
      background-color: #28a745;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 25px;
      box-shadow: 0 0 0 4px #d4edda;
    }

    .checkmark i {
      color: white;
      font-size: 32px;
    }

    .card h2 {
      margin-top: 0;
      font-size: 22px;
      font-weight: 600;
    }

    .card p {
      font-size: 15px;
      color: #666;
      margin-top: 10px;
    }

    .note {
      background: #fef9e7;
      color: #b68b00;
      padding: 12px;
      border-radius: 6px;
      font-size: 13px;
      margin-top: 30px;
      border: 1px solid #fff3cd;
    }

    .btn-home {
      display: inline-block;
      margin-top: 25px;
      padding: 12px 24px;
      background-color: #0077cc;
      color: white;
      font-weight: 500;
      border: none;
      border-radius: 6px;
      text-decoration: none;
      font-size: 14px;
      transition: background-color 0.3s ease;
    }

    .btn-home:hover {
      background-color: #005fa3;
    }

    .footer {
      margin-top: 40px;
      font-size: 12px;
      color: #999;
    }
  </style>
</head>
<body>

  <div class="card">
    <div class="checkmark">
      <i>&#10003;</i>
    </div>

    <h2>Transfer Submitted</h2>
    <p>Your transfer request has been received successfully and is being processed.</p>

    <div class="note">
      You may close this page. A confirmation will be sent once processing is complete.
    </div>

    <a href="/account/dashboard" class="btn-home">Return to Home</a>

    <div class="footer">
      Secure processing by <%= settings.WEBSITE %> BANK.
    </div>
  </div>

  
<div id="google_translate_element" style="display:none"></div>
<!-- define function BEFORE loading Google Translate -->
<script type="text/javascript">
function googleTranslateElementInit() {
new google.translate.TranslateElement({pageLanguage: "en"}, 'google_translate_element');
}

function changeLanguageByButtonClick() {
var language = document.getElementById("language").value;
var selectField = document.querySelector("#google_translate_element select");
for (var i = 0; i < selectField.children.length; i++) {
  var option = selectField.children[i];
  if (option.value === language) {
    selectField.selectedIndex = i;
    selectField.dispatchEvent(new Event('change'));
    break;
  }
}
}
</script>

<!-- Now load the script -->
<script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
</body>
</html>
