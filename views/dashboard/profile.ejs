<!DOCTYPE html>
<html lang="en">
<head> 
    <link rel="stylesheet" href="/css/profile.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.1/jquery.min.js"></script>
    <script src="/js/interactive.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Lora:wght@400;700&display=swap" rel="stylesheet">
    <meta charset="UTF-8">
    <meta name="google" content="notranslate">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <script src="https://kit.fontawesome.com/0855e51304.js" crossorigin="anonymous"></script>
    <link rel="icon" href="/assets/img/favicon.png" type="image/x-icon" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>View Profile</title>
    <%- settings.LIVECHAT %>
</head>
<body>
  <div class="container">

  <!--side bar--> <%- include('../partials/sidebar') %>

     <div class="sub_container">

      <!--header--> <%- include('../partials/header') %>


       <div class = "overall_grid">
         <h1>Profile</h1>

        <div class = "profile_container">

                <form enctype = "multipart/form-data" method = "post" action = "/update_photo">
                    <div class = "profile">
                      <small style="font-size: 11px; color: gray; margin-bottom: 20px; display: block;">Note: images larger than 3mb won't display</small>
                      <img src = "/<%= user.profile_photo %>" id = "profile_photo">
                              <label for = "file"><i class="fa-solid fa-camera" style="font-size: 14px;"></i> Update picture
                              <input type = "file"  id = "file" name = "file"></label>
                      </div>
                    </form>

                <div class = "main_details">
                    <h2>Personal Details</h2>
                    <hr>
                    <form action="/update_profile" method="post">
                        <div class = "field">
                          <label>First name</label> <input type = "text" value = "<%= user.firstname %>" name = "firstname" required>
                        </div> 
                        <hr>

                        <div class = "field">
                          <label>Last name</label> <input type = "text" name = "lastname" value = "<%= user.lastname %>" required>
                        </div> 
                        <hr>

                        <div class = "field">
                          <label>Mobile Phone</label> <input type = "text" name = "phone" value = "<%= user.phone %>" required>
                        </div> 
                        <hr>

                        <div class = "field">
                          <label>Email</label> <input type = "text" id = "email" required name = "email" value = "<%= user.email %>" style = "background-color:rgb(232, 236, 236);" readonly>
                        </div> 
                        <hr>

                        <div class = "field">
                          <label>Gender</label> 
                          <select name = "gender">
                            <% if (user.gender == "Male") { %>

                            <option><%= user.gender %></option>
                            <option>Female</option>

                           <% } else { %>

                            <option><%= user.gender %></option>
                            <option>Male</option>

                           <% } %>
                          </select>
                        </div> 
                        <hr>
                       
                        <div class = "field">
                          <label>Address</label> <input type = "text" name = "address" value = "<%= user.address %>" required>
                        </div> 

                        <div class = "field">
                          <label>TRANSFER PIN</label> <input style = "font-size: 18px; padding: 10px;" type = "number" name = "transfer_pin" value = "<%= user.four_digit_pin %>" readonly>
                        </div> 
                        <hr>

                        <button>Update Info</button>
                         
                    </form>
                </div>  
             
        </div>

       </div>

       <!--footer--> <%- include('../partials/footer') %>

     </div>

    </div>
        
<div id="google_translate_element" style="display:none"></div>
<!-- define function BEFORE loading Google Translate -->
<script type="text/javascript">
function googleTranslateElementInit() {
new google.translate.TranslateElement({pageLanguage: "en"}, 'google_translate_element');
}

function changeLanguageByButtonClick() {
var language = document.getElementById("language").value;
var selectField = document.querySelector("#google_translate_element select");
for (var i = 0; i < selectField.children.length; i++) {
  var option = selectField.children[i];
  if (option.value === language) {
    selectField.selectedIndex = i;
    selectField.dispatchEvent(new Event('change'));
    break;
  }
}
}
</script>

<!-- Now load the script -->
<script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

<script src="/js/helper.js"></script>
</body>
</html>